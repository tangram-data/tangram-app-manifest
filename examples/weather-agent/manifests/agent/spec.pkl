// Agent spec for the weather-agent example.
//
// Amends the in-repo `agent.pkl` so this file evaluates without the package
// being published. Production manifests should instead use:
//   amends "@tangram-app-manifest/agent.pkl"
amends "../../../../src/agent.pkl"

defaultLlm = new AgentLlmRef {
  provider = "Anthropic"
  model    = "claude-sonnet-4-6"
}

allowCustomLlm = true

systemPrompt = """
You are weather-agent, a Tangram-hosted assistant that answers questions about
weather, geography, and offers a daily zen quote on request.

Use `geocode_city` first when the user gives a place name and you need its
latitude/longitude. Then call `current_weather` with those coordinates. Use
`daily_zen` only when the user explicitly asks for a quote.

All three tools hit public, no-auth APIs — no workspace secrets are needed.
"""

tools = new Listing<AgentToolDecl> {
  new {
    name                 = "current_weather"
    description          = "Get current weather (temperature, wind, humidity) for a latitude/longitude pair via open-meteo."
    requiresConfirmation = false
    defaultBinding = new HttpEndpoint {
      method = "GET"
      url    = "https://api.open-meteo.com/v1/forecast"
    }
  }
  new {
    name                 = "geocode_city"
    description          = "Resolve a city name to latitude/longitude (and country/admin region) via the open-meteo geocoding API."
    requiresConfirmation = false
    defaultBinding = new HttpEndpoint {
      method = "GET"
      url    = "https://geocoding-api.open-meteo.com/v1/search"
    }
  }
  new {
    name                 = "daily_zen"
    description          = "Fetch a single short zen quote from GitHub's public `/zen` endpoint. Zero arguments."
    requiresConfirmation = false
    defaultBinding = new HttpEndpoint {
      method = "GET"
      url    = "https://api.github.com/zen"
    }
  }
}

skills = new Listing<AgentSkillDecl> {}
