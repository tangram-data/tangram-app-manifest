// Example AgentApp identity. Run `pkl eval app.pkl` from this directory to
// verify the manifest parses against the local schema.
//
// Real manifests would reference the published package via
//   import "@tangram-app-manifest/core.pkl" as tangram
// We use a relative import here so the example evaluates against the
// in-repo source without needing the package to be published.
import "../../../src/core.pkl" as tangram

manifestSpecVersion = tangram.MANIFEST_SPEC_VERSION

appType = tangram.AGENT_APP_TYPE
group   = "com.example"
name    = "weather-agent"
version = "0.1.0"

license     = "Apache-2.0"
category    = "Demo"
description = "An AgentApp that answers weather and geocoding questions using public no-auth APIs."
readme      = read("README.md").text
tags        = List("agent", "weather", "demo")
