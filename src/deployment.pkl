module ai.tangram.os
import "pkl:json"

class DeploymentContext {
  id: String
  tangramOSPublicUrl: String
  workspace: String
  k8sNamespace: String
}

context = new DeploymentContext {
  id = read("prop:tangram_app_deployment_id")
  tangramOSPublicUrl = read("prop:tangram_os_public_url")
  workspace = read("prop:tangram_app_deployment_workspace")
  k8sNamespace = read("prop:tangram_app_deployment_k8s_namespace")
}

class ContainerFile {
  name: String
  path: String
  isSensitive: Boolean? = false
  content: String
}

class AppComponentServiceSpec {
  port: Int
  targetPort: Int
  protocol: String
}

class AppContainerMeta {
  name: String
  image: String
  description: String?
}

class AppComponentMeta extends Annotation {
  name: String
  initContainers: List<AppContainerMeta>?
  containers: List<AppContainerMeta>
  apiServiceComponent: Boolean? = false
  maxReplica: Int?
  recommendedReplica: Int? = 1
  optional: Boolean? = false
}

class AppContainerSpec {
  ports: List<Int>
  variables: Map<String, String>
  files: List<ContainerFile>
  command: List<String>
  args: List<String>?
}

class AppComponentSpec {
  service: AppComponentServiceSpec?
  initContainers: List<AppContainerSpec>?
  containers: List<AppContainerSpec>
}

function getDeploymentConfig(): Dynamic =
  (new json.Parser {}.parse(read("prop:deploymentConfig")) as Dynamic)

function formatCpuQuantity(cpuQuantity: Dynamic) =
  if (cpuQuantity.unit == "Milli")
    "\(cpuQuantity.quantity)m"
  else "\(cpuQuantity.quantity)"

function formatMemoryQuantity(memoryQuantity: Dynamic) =
  if (memoryQuantity.unit == "Bytes")
    "\(memoryQuantity.quantity)"
  else "\(memoryQuantity.quantity)\(memoryQuantity.unit)"

function getComponentReplicas(component: String) =
  getDeploymentConfig().components.getProperty(component).replicas

function getComponentContainerK8sCpuQuanity(component: String, container: String)
= formatCpuQuantity(getDeploymentConfig().components.getProperty(component).containerResourceRequests.getProperty(container).cpu)
function getComponentContainerK8sMemoryQuanity(component: String, container: String)
= formatMemoryQuantity(getDeploymentConfig().components.getProperty(component).containerResourceRequests.getProperty(container).memory)


function getConfig(key: String) = getDeploymentConfig().settings.getProperty(key)
function getOptionalConfig(key: String)= getDeploymentConfig().settings.getPropertyOrNull(key)

function getSecret(key: String) = getDeploymentConfig().secrets.getProperty(key)
function getOptionalSecret(key: String) = getDeploymentConfig().secrets.getPropertyOrNull(key)

function getImagePullSecretName()  = read?("prop:imagePullSecretName")