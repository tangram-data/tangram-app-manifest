module ai.tangram.os

// Current manifest schema version. Apps should reference this in app.pkl as:
//   manifestSpecVersion = tangram.MANIFEST_SPEC_VERSION
MANIFEST_SPEC_VERSION = "v1"

TANGRAM_OS_GROUP_NAME = "ai.tangram-os"

class AppName {
  group: String
  name: String
}

TANGRAM_OS_CORE_APP = new AppName {
  group = TANGRAM_OS_GROUP_NAME
  name = "core"
}

class ResourceType {
  app: AppName
  name: String
}

// ---------------------------------------------------------------------------
// Privilege constants
//
// Privileges are open strings — any value is accepted so apps can define
// domain-specific privileges (e.g. "Approve", "Publish").
// These well-known constants are provided for convenience and referenced by
// the platform for built-in policy evaluation.
//
// Usage in resource_types.pkl:
//   local Describe = tangram.Privilege.Describe
//   ...or just use the string directly: privilege = "Describe"
// ---------------------------------------------------------------------------
class _PrivilegeConstants {
  Describe: String = "Describe"
  Read:     String = "Read"
  Write:    String = "Write"
  Create:   String = "Create"
  Delete:   String = "Delete"
  Admin:    String = "Admin"
  Execute:  String = "Execute"
}
Privilege: _PrivilegeConstants = new _PrivilegeConstants {}

// ---------------------------------------------------------------------------
// Effect constants
//
// Characterises what an action does to the world. Drives AI autonomy decisions,
// audit policy, and UI affordances.
//
//   Stateless    — reads only; no state change; AI executes autonomously; audit skipped by default
//   Reversible   — mutates state; prior state restorable; audit always recorded
//   Irreversible — mutates state; cannot be undone; AI requires confirmation; audit always recorded
// ---------------------------------------------------------------------------
class _EffectConstants {
  Stateless:    String = "Stateless"
  Reversible:   String = "Reversible"
  Irreversible: String = "Irreversible"
}
Effect: _EffectConstants = new _EffectConstants {}

// ---------------------------------------------------------------------------
// Resource name extractors
//
// Used in OpenApiMapping.resourceName and ResourcePrivilegeRequirement.resourceName
// to identify which parts of an HTTP request form the resource name.
// ---------------------------------------------------------------------------
abstract class ResourceNameExtractor {}

/// Extracts from a URL path parameter (OpenAPI `in: path`).
class PathParam extends ResourceNameExtractor {
  name: String
}

/// Extracts from a URL query-string parameter (OpenAPI `in: query`). Distinguished
/// from `PathParam` so the runtime gateway resolves the correct value even when an
/// operation declares a path param and a query param with the same name (legal per
/// the OpenAPI spec — parameter uniqueness is the pair `(name, in)`).
class QueryParam extends ResourceNameExtractor {
  name: String
}

/// Extracts from a request body field (dot-separated path).
/// `index` is only needed when the field is an array.
class BodyField extends ResourceNameExtractor {
  path: String
  index: Int?
}

// ---------------------------------------------------------------------------
// OpenAPI mapping — binds an action to one HTTP operationId.
// ---------------------------------------------------------------------------
class OpenApiMapping {
  operationId: String
  /// How to extract the resource name from the request.
  /// When omitted, the platform derives it from path parameters in URL order.
  resourceName: List<ResourceNameExtractor>?
}

// ---------------------------------------------------------------------------
// Additional privilege check — cross-resource authorization required on an action.
// ---------------------------------------------------------------------------
class ResourcePrivilegeRequirement {
  /// Resource type identifier: "group/app/TypeName" or just "TypeName" if same app.
  resourceType: String
  privilege: String
  resourceName: List<ResourceNameExtractor>
}

// ---------------------------------------------------------------------------
// Action
// ---------------------------------------------------------------------------
class Action {
  name: String
  /// Privilege class this action belongs to.
  /// Defaults to the action name when it matches a well-known privilege.
  privilege: String?
  /// Characterises the action's effect: Stateless, Reversible, or Irreversible.
  effect: String
  idempotent: Boolean
  doc: String
  skipAuth: Boolean?
  skipAudit: Boolean?
  requiresConfirmation: Boolean?
  additionalPrivileges: List<ResourcePrivilegeRequirement>?
  /// HTTP binding for a single operationId.
  openApiMapping: OpenApiMapping?
  /// HTTP bindings for multiple operationIds (e.g. native API + Tangram wrapper API).
  openApiMappings: List<OpenApiMapping>?
}

// ---------------------------------------------------------------------------
// Resource type versioning
// ---------------------------------------------------------------------------
class ResourceTypeVersion {
  version: String
  served: Boolean
  superTypeVersion: String?
  actions: List<Action>
}

class ResourceTypeDefinition {
  name: String
  doc: String
  activeVersion: String
  versions: List<ResourceTypeVersion>
  superType: ResourceType?
  scopeType: ResourceType?
  /// (Reserved — not yet enforced by the platform IAM.) Maps a parent-scope privilege
  /// to the list of child privileges it grants. Will become operative when the IAM
  /// permission-check query consults this field; until then, declaring it has no
  /// runtime effect — prefer to omit it on new manifests to avoid drift.
  scopePrivilegePropagation: Map<String, List<String>>?
}

// ---------------------------------------------------------------------------
// Platform super types
// ---------------------------------------------------------------------------
WORKSPACE_TYPE = new ResourceType {
  app = TANGRAM_OS_CORE_APP
  name = "Workspace"
}

DATASET_TYPE = new ResourceType {
  app = TANGRAM_OS_CORE_APP
  name = "Dataset"
}

CATALOG_TYPE = new ResourceType {
  app = TANGRAM_OS_CORE_APP
  name = "DataCatalog"
}

STORAGE_TYPE = new ResourceType {
  app = TANGRAM_OS_CORE_APP
  name = "Storage"
}

DATABASE_TYPE = new ResourceType {
  app = TANGRAM_OS_CORE_APP
  name = "Database"
}

COMPUTE_TYPE = new ResourceType {
  app = TANGRAM_OS_CORE_APP
  name = "Compute"
}

SQL_ENGINE_TYPE = new ResourceType {
  app = TANGRAM_OS_CORE_APP
  name = "SQLEngine"
}

WORKFLOW_TYPE = new ResourceType {
  app = TANGRAM_OS_CORE_APP
